# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database (for Prisma CLI operations)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# AI (optional, for AI-assisted features)
GEMINI_API_KEY=

# NWA Foundation join URL (optional, shows "Registration Coming Soon" if empty)
NEXT_PUBLIC_NWA_JOIN_URL=
